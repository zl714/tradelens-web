# Copy this file to ".env" (which is git-ignored) and fill in your own key.
# Get a free API key at https://site.financialmodelingprep.com/developer/docs
#
# If this variable is NOT set, MarketLens automatically serves bundled sample
# data and shows a "Demo data" badge — the app still works end-to-end.

FMP_API_KEY=your_financial_modeling_prep_api_key_here
